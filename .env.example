# DeepSeek API (https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Target — the web app Argus will scan
# For local development via SSH tunnel to Oracle Juice Shop:
TARGET_URL=http://localhost:3000

# Scan behavior
MAX_CRAWL_DEPTH=3
MAX_CRAWL_PAGES=200
SCAN_TIMEOUT=300
LOG_LEVEL=INFO

# Optional path to a YAML file declaring known forms / API endpoints
# the static crawler can't discover (SPAs, JSON APIs, etc.)
SEED_FORMS=seed_forms.yml

# Where scan reports get written
REPORTS_DIR=reports
#env.example